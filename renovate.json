{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "docker:enableMajor"
  ],
  "mode": "default",
  "baseBranches": ["dev"],

  "schedule": ["before 9am on monday"],
  "timezone": "Europe/Kiev",

  "dependencyDashboard": true,
  "platformAutomerge": true,
  "prHourlyLimit": 5,
  "labels": ["dependencies"],

  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },

  "pre-commit": {
    "enabled": true
  },

  "packageRules": [
    {
      "description": "Auto-merge patch updates",
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Databases - stable, auto-merge minor",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["pgvector/pgvector", "redis", "qdrant/qdrant"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "groupName": "databases"
    },
    {
      "description": "Langfuse Docker - auto-merge minor/patch",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["langfuse/langfuse", "langfuse/langfuse-worker"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "groupName": "langfuse"
    },
    {
      "description": "ML Platform - group together, LiteLLM uses loose versioning for rc tags",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/berriai/litellm"
      ],
      "groupName": "ml-platform",
      "ignoreUnstable": false,
      "versioning": "loose"
    },
    {
      "description": "AI Services - group docling and lightrag",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/docling-project/docling-serve-cpu",
        "quay.io/docling-project/docling-serve",
        "ghcr.io/hkuds/lightrag"
      ],
      "groupName": "ai-services"
    },
    {
      "description": "Monitoring - group loki, promtail, alertmanager",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "grafana/loki",
        "grafana/promtail",
        "prom/alertmanager"
      ],
      "groupName": "monitoring"
    },
    {
      "description": "ClickHouse - CalVer versioning (26.3, 26.3.3.20-lts)",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["clickhouse/clickhouse-server"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)(\\.(?<patch>\\d+))?(\\.\\d+)?(-(?<compatibility>.*))?$",
      "groupName": "clickhouse"
    },
    {
      "description": "LiveKit - handle v-prefix tags with loose versioning",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["livekit/livekit-server", "livekit/sip"],
      "versioning": "loose",
      "groupName": "livekit"
    },
    {
      "description": "MinIO - regex versioning for RELEASE.YYYY-MM-DD tags",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["minio/minio"],
      "versioning": "regex:^RELEASE\\.(?<major>\\d{4})-(?<minor>\\d{2})-(?<patch>\\d{2})T\\d{2}-\\d{2}-\\d{2}Z$",
      "groupName": "storage"
    },
    {
      "description": "Base images - Python",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["python"],
      "groupName": "python-base"
    },
    {
      "description": "Base images - uv",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/astral-sh/uv"],
      "groupName": "uv-base"
    },
    {
      "description": "Base images - Node.js and nginx",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["node", "nginx"],
      "groupName": "node-nginx-base"
    },
    {
      "description": "Pre-commit hooks - group together",
      "matchManagers": ["pre-commit"],
      "groupName": "pre-commit-hooks",
      "automerge": true
    },
    {
      "description": "Mini app build/test toolchain - keep Vite and Vitest majors aligned",
      "matchManagers": ["npm"],
      "matchFileNames": ["mini_app/frontend/package.json"],
      "matchPackageNames": ["vite", "vitest", "@vitejs/plugin-react"],
      "groupName": "mini-app-vite-toolchain"
    },
    {
      "description": "NPM packages - React core and router",
      "matchManagers": ["npm"],
      "matchFileNames": ["mini_app/frontend/package.json"],
      "matchPackageNames": ["react", "react-dom", "react-router-dom"],
      "groupName": "npm-react"
    },
    {
      "description": "NPM packages - React ecosystem",
      "matchManagers": ["npm"],
      "matchFileNames": ["mini_app/frontend/package.json"],
      "matchPackageNames": ["zustand", "@tma.js/sdk-react", "@types/react", "@types/react-dom"],
      "groupName": "npm-react-ecosystem"
    },
    {
      "description": "NPM packages - TypeScript and types",
      "matchManagers": ["npm"],
      "matchFileNames": ["mini_app/frontend/package.json"],
      "matchPackageNames": ["typescript"],
      "groupName": "npm-typescript"
    },
    {
      "description": "NPM packages - Testing libraries",
      "matchManagers": ["npm"],
      "matchFileNames": ["mini_app/frontend/package.json"],
      "matchPackageNames": ["@testing-library/jest-dom", "@testing-library/react", "@testing-library/user-event", "jsdom"],
      "groupName": "npm-testing"
    },
    {
      "description": "NPM packages - Dev tools",
      "matchManagers": ["npm"],
      "matchFileNames": ["mini_app/frontend/package.json"],
      "matchPackageNames": ["eruda"],
      "groupName": "npm-dev"
    },
    {
      "description": "Python core libs - safe, auto-merge patch",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "pydantic",
        "httpx",
        "uvicorn",
        "python-dotenv",
        "prometheus-client",
        "sentry-sdk",
        "tenacity",
        "tqdm",
        "rich",
        "cachetools",
        "orjson"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "groupName": "python-core-libs"
    },
    {
      "description": "Python ML libs - group, no auto-merge",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "transformers",
        "sentence-transformers",
        "FlagEmbedding",
        "torch",
        "numpy",
        "scipy",
        "torchvision"
      ],
      "groupName": "python-ml-libs"
    },
    {
      "description": "Python RAG stack - group",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "qdrant-client",
        "langfuse",
        "langchain",
        "langchain-core",
        "langchain-openai",
        "cocoindex",
        "ragas",
        "deepeval"
      ],
      "groupName": "python-rag-stack"
    },
    {
      "description": "Python LangGraph - group",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "langgraph",
        "langgraph-checkpoint-postgres",
        "langgraph-checkpoint-redis",
        "langmem"
      ],
      "groupName": "python-langgraph"
    },
    {
      "description": "Python bot - group",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "aiogram",
        "redisvl",
        "aiogram-dialog",
        "fluentogram",
        "fluent-compiler"
      ],
      "groupName": "python-bot"
    },
    {
      "description": "Python document processing - group",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "docling",
        "docling-core",
        "docling-parse",
        "pymupdf",
        "fastembed"
      ],
      "groupName": "python-docling"
    },
    {
      "description": "Python API clients - group",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "anthropic",
        "openai",
        "groq",
        "voyageai",
        "instructor",
        "aiohttp",
        "requests",
        "grpcio"
      ],
      "groupName": "python-api-clients"
    },
    {
      "description": "Python voice/LiveKit - group",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "livekit",
        "livekit-agents",
        "livekit-plugins-elevenlabs",
        "livekit-plugins-openai"
      ],
      "groupName": "python-livekit"
    },
    {
      "description": "Python OpenTelemetry - group",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "opentelemetry-sdk",
        "opentelemetry-exporter-otlp-proto-http",
        "opentelemetry-exporter-otlp-proto-grpc"
      ],
      "groupName": "python-opentelemetry"
    },
    {
      "description": "Python async - group",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "asyncpg",
        "uvloop",
        "apscheduler",
        "phonenumbers",
        "click"
      ],
      "groupName": "python-async"
    },
    {
      "description": "Python FastAPI - group",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "fastapi"
      ],
      "groupName": "python-fastapi"
    },
    {
      "description": "Python data - group",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "datasets",
        "pandas"
      ],
      "groupName": "python-data"
    },
    {
      "description": "Python docs - group",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "mkdocs",
        "mkdocs-material",
        "mkdocstrings"
      ],
      "groupName": "python-docs"
    },
    {
      "description": "Python ML serving - group",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "onnxruntime",
        "optimum",
        "python-multipart"
      ],
      "groupName": "python-ml-serving"
    },
    {
      "description": "Dev tools - ruff, mypy, pytest",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "ruff",
        "mypy",
        "pytest",
        "pytest-httpx",
        "pytest-cov",
        "pytest-asyncio",
        "pytest-timeout",
        "pytest-xdist",
        "pytest-split",
        "pre-commit",
        "pylint",
        "bandit",
        "vulture",
        "click",
        "fakeredis"
      ],
      "groupName": "python-dev-tools"
    },
    {
      "description": "Dev tools - telethon",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "telethon"
      ],
      "groupName": "python-telethon"
    },
    {
      "description": "GitHub Actions - group",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    }
  ]
}
