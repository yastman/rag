# Server Environment Configuration (для запуска на сервере)
# Используйте этот файл когда запускаете скрипты НА СЕРВЕРЕ
# Команда: cp .env.server .env

# Z.AI API Configuration (deprecated - switching to OpenAI/Groq)
ZAI_API_KEY=REDACTED_ZAI_KEY

# OpenAI API
OPENAI_API_KEY=REDACTED_OPENAI_KEY

# Groq API
GROQ_API_KEY=REDACTED_GROQ_KEY

# Qdrant (LOCAL - на том же сервере)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=REDACTED_QDRANT_KEY

# BGE-M3 API
BGE_M3_URL=http://localhost:8001

# Docling API
DOCLING_URL=http://localhost:5001
ANTHROPIC_API_KEY=REDACTED_ANTHROPIC_KEY
