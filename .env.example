# ==============================================================================
# КОНФИГУРАЦИЯ ОКРУЖЕНИЯ
# ==============================================================================
#
# ДЛЯ ЛОКАЛЬНОЙ РАБОТЫ (подключение к удаленному серверу):
#   - Используйте этот файл как .env
#   - QDRANT_URL=http://95.111.252.29:6333
#
# ДЛЯ РАБОТЫ НА СЕРВЕРЕ (локальное подключение):
#   - Используйте .env.server: cp .env.server .env
#   - QDRANT_URL=http://localhost:6333
# ==============================================================================

# =============================================================================
# Docker Compose environment selection
# =============================================================================
# Local dev (default):
COMPOSE_FILE=compose.yml:compose.dev.yml
COMPOSE_PROJECT_NAME=dev
# VPS production (set on VPS):
# COMPOSE_FILE=compose.yml:compose.vps.yml
# COMPOSE_PROJECT_NAME=vps

# =============================================================================
# REQUIRED FOR BOT PROFILE (make docker-bot-up)
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_DEV=  # Optional local-only token to avoid getUpdates conflict with prod bot
LITELLM_MASTER_KEY=

# =============================================================================
# LOCAL EMBEDDINGS (BGE-M3, default for dev and VPS)
# =============================================================================
BGE_M3_TIMEOUT=120
COLBERT_TIMEOUT=120
RERANK_CANDIDATES_MAX=10
# Skip reranking when RRF fusion score >= threshold
# Must be > 1/61 (≈0.01639, single-query top-1 RRF) to avoid always skipping
SKIP_RERANK_THRESHOLD=0.018
OMP_NUM_THREADS=4
MKL_NUM_THREADS=4

# =============================================================================
# DATABASE CREDENTIALS (compose services)
# =============================================================================
POSTGRES_PASSWORD=postgres  # Change in production!
REDIS_PASSWORD=dev_redis_pass  # Change in production!
REDIS_MAXMEMORY=512mb  # dev: 512mb, VPS: 256mb (default in compose.yml)

# =============================================================================
# REQUIRED FOR ML PROFILE (make docker-ml-up, langfuse)
# =============================================================================
NEXTAUTH_SECRET=   # generate: openssl rand -base64 32
SALT=              # generate: openssl rand -base64 32
ENCRYPTION_KEY=    # generate: openssl rand -hex 32

# =============================================================================
# DEV INFRASTRUCTURE (optional overrides, defaults work out of the box)
# =============================================================================
# CLICKHOUSE_PASSWORD=clickhouse
# MINIO_ROOT_PASSWORD=miniosecret
# LANGFUSE_REDIS_PASSWORD=langfuseredis

# =============================================================================
# LLM PROVIDERS (at least one required for bot profile)
# =============================================================================
CEREBRAS_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Anthropic Claude API (optional)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Z.AI API Configuration (deprecated)
ZAI_API_KEY=your-zai-key-here

# Qdrant Vector Database
# Local development (Docker internal):
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=gdrive_documents_bge
QDRANT_HISTORY_COLLECTION=conversation_history
# HISTORY_RELEVANCE_THRESHOLD=0.7  # Min similarity score for history results (0.0-1.0, default 0.7; #433)

# BGE-M3 Embedding API (Docker internal, used by bot automatically)
# BGE_M3_URL=http://localhost:8000

# Docling API (optional)
DOCLING_URL=http://localhost:5001

# =============================================================================
# DEV STACK CONFIGURATION
# =============================================================================

# Telegram Bot (TELEGRAM_BOT_TOKEN defined above in required section)
LLM_BASE_URL=http://localhost:4000
LLM_MODEL=gpt-4o-mini
CLIENT_DIRECT_PIPELINE_ENABLED=true
SUPERVISOR_MAX_TOKENS=1024
# TTFT drift warning threshold (ms). Raise for reasoning models behind proxy (#675)
TTFT_DRIFT_WARN_MS=500
# Reasoning control for Cerebras models (#718)
# REASONING_EFFORT=low        # gpt-oss-120b: low/medium(default)/high
# REASONING_FORMAT=hidden      # gpt-oss-120b: hidden/parsed/raw/none
# DISABLE_REASONING=true       # zai-glm-4.7: true/false

# Qdrant Quantization (bot)
QDRANT_QUANTIZATION_MODE=off
QDRANT_USE_QUANTIZATION=true
QDRANT_QUANTIZATION_RESCORE=true
QDRANT_QUANTIZATION_OVERSAMPLING=2.0

# Small-to-big context expansion (bot)
SMALL_TO_BIG_MODE=off
SMALL_TO_BIG_WINDOW_BEFORE=1
SMALL_TO_BIG_WINDOW_AFTER=1
MAX_EXPANDED_CHUNKS=10
MAX_CONTEXT_TOKENS=8000

# LightRAG (uses OpenAI for LLM and embeddings)
# OPENAI_API_KEY is already defined above

# Langfuse (optional - for LLM tracing)
# Local dev default points to dockerized Langfuse on :3001.
# On VPS without local Langfuse, set LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-dev
LANGFUSE_SECRET_KEY=sk-lf-dev
LANGFUSE_HOST=http://localhost:3001
# Isolate traces by environment in Langfuse UI (prod/staging/dev). Optional.
# LANGFUSE_TRACING_ENVIRONMENT=staging
# Flush config (defaults match Langfuse SDK: flush_at=512, flush_interval=5.0s). Optional.
# LANGFUSE_FLUSH_AT=512
# LANGFUSE_FLUSH_INTERVAL=5.0
# Prompt label to fetch from Langfuse (default: production). Optional.
# LANGFUSE_PROMPT_LABEL=production

# Search & retrieval tuning
# SEARCH_TOP_K=20                    # Qdrant hybrid search top-k (default 20)
# RELEVANCE_THRESHOLD_RRF=0.005      # Min RRF score to keep a document (default 0.005)

# Content filter / guard
# GUARD_MODE=hard                    # hard (block) | soft (flag+continue) | log (log only)

# MLflow (optional - for experiment tracking)
MLFLOW_TRACKING_URI=http://localhost:5000

# Voyage AI (OPTIONAL — legacy, not used in default dev/VPS config)
# VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3-large
VOYAGE_CACHE_MODEL=voyage-3-lite
VOYAGE_RERANK_MODEL=rerank-2

# =============================================================================
# LITELLM PROXY (LLM Gateway)
# =============================================================================
# LITELLM_MASTER_KEY, CEREBRAS_API_KEY, OPENAI_API_KEY, GROQ_API_KEY
# are all defined above in required/LLM providers sections

# =============================================================================
# E2E TESTING (Telethon userbot)
# =============================================================================
# Get credentials from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your-api-hash-here
E2E_BOT_USERNAME=@test_nika_homes_bot

# =============================================================================
# ALERTING (Telegram notifications via Alertmanager)
# =============================================================================
# Create a separate bot for alerts via @BotFather (not the main bot!)
# See docs/ALERTING.md for setup instructions
TELEGRAM_ALERTING_BOT_TOKEN=your-alerting-bot-token
# Chat ID for alerts (use @userinfobot to get your chat ID)
# For groups: add bot to group and use negative chat ID
TELEGRAM_ALERTING_CHAT_ID=-1001234567890

# =============================================================================
# VOICE BOT (LiveKit Agents + SIP)
# =============================================================================
ELEVENLABS_API_KEY=
LIVEKIT_URL=ws://livekit-server:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIFECELL_SIP_USER=
LIFECELL_SIP_PASS=
RAG_API_URL=http://rag-api:8080
VOICE_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# =============================================================================
# SESSION SUMMARY + CRM (#305)
# =============================================================================
SESSION_SUMMARY_ENABLED=false
SESSION_TIMEOUT_MINUTES=30
KOMMO_ENABLED=false
KOMMO_SUBDOMAIN=
KOMMO_ACCESS_TOKEN=
KOMMO_TELEGRAM_FIELD_ID=0

# Kommo OAuth2 (for token refresh)
KOMMO_CLIENT_ID=
KOMMO_CLIENT_SECRET=
KOMMO_REDIRECT_URI=
KOMMO_AUTH_CODE=

# Kommo pipeline config
KOMMO_DEFAULT_PIPELINE_ID=0
KOMMO_RESPONSIBLE_USER_ID=
KOMMO_SESSION_FIELD_ID=0
KOMMO_LEAD_SCORE_FIELD_ID=0
KOMMO_LEAD_BAND_FIELD_ID=0
KOMMO_NEW_STATUS_ID=0
KOMMO_SERVICE_FIELD_ID=0
KOMMO_SOURCE_FIELD_ID=0
KOMMO_TELEGRAM_USERNAME_FIELD_ID=0

# Manager config
MANAGER_IDS=
MANAGER_HOT_LEAD_THRESHOLD=60
MANAGER_HOT_LEAD_DEDUPE_SEC=3600

# Real Estate Database
REALESTATE_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/realestate

# ── Handoff (Forum Topics) ──────────────────────────────────────
# MANAGERS_GROUP_ID=-1001234567890   # Supergroup with Topics enabled
# HANDOFF_TTL_HOURS=24
# HANDOFF_SUMMARY_MIN_MESSAGES=3
# BUSINESS_HOURS_START=9
# BUSINESS_HOURS_END=18
# BUSINESS_HOURS_TZ=Europe/Sofia
# HANDOFF_WAIT_TIMEOUT_MIN=15
