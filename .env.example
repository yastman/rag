# ==============================================================================
# КОНФИГУРАЦИЯ ОКРУЖЕНИЯ
# ==============================================================================
#
# ДЛЯ ЛОКАЛЬНОЙ РАБОТЫ (подключение к удаленному серверу):
#   - Используйте этот файл как .env
#   - QDRANT_URL=http://REDACTED_VPS_IP:6333
#
# ДЛЯ РАБОТЫ НА СЕРВЕРЕ (локальное подключение):
#   - Используйте .env.server: cp .env.server .env
#   - QDRANT_URL=http://localhost:6333
# ==============================================================================

# Z.AI API Configuration (deprecated - switching to OpenAI/Groq)
ZAI_API_KEY=your-zai-key-here

# OpenAI API
OPENAI_API_KEY=your-openai-key-here

***REMOVED*** API
GROQ_API_KEY=your-groq-key-here

***REMOVED*** Claude API
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

***REMOVED*** Vector Database
# Для локальной работы (подключение к серверу):
QDRANT_URL=http://REDACTED_VPS_IP:6333
# Для работы на сервере раскомментируйте:
# QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=contextual_bulgaria_voyage

# BGE-M3 Embedding API (optional)
BGE_M3_URL=http://localhost:8001

# Docling API (optional)
DOCLING_URL=http://localhost:5001

# =============================================================================
# DEV STACK CONFIGURATION
# =============================================================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
LLM_BASE_URL=http://localhost:4000
LLM_MODEL=gpt-4o-mini

***REMOVED*** Quantization (bot)
QDRANT_QUANTIZATION_MODE=off
QDRANT_USE_QUANTIZATION=true
QDRANT_QUANTIZATION_RESCORE=true
QDRANT_QUANTIZATION_OVERSAMPLING=2.0

# Small-to-big context expansion (bot)
SMALL_TO_BIG_MODE=off
SMALL_TO_BIG_WINDOW_BEFORE=1
SMALL_TO_BIG_WINDOW_AFTER=1
MAX_EXPANDED_CHUNKS=10
MAX_CONTEXT_TOKENS=8000

# LightRAG (uses OpenAI for LLM and embeddings)
# OPENAI_API_KEY is already defined above

# Langfuse (optional - for LLM tracing)
LANGFUSE_PUBLIC_KEY=pk-lf-dev
LANGFUSE_SECRET_KEY=sk-lf-dev
LANGFUSE_HOST=http://localhost:3001

# MLflow (optional - for experiment tracking)
MLFLOW_TRACKING_URI=http://localhost:5000

***REMOVED*** AI
VOYAGE_API_KEY=your_voyage_api_key_here
VOYAGE_EMBED_MODEL=voyage-3-large
VOYAGE_CACHE_MODEL=voyage-3-lite
VOYAGE_RERANK_MODEL=rerank-2

# =============================================================================
# LITELLM PROXY (LLM Gateway)
# =============================================================================
# Master key for LiteLLM authentication
LITELLM_MASTER_KEY=sk-litellm-master-dev

# Primary LLM provider (Cerebras)
CEREBRAS_API_KEY=your-cerebras-key-here

# Fallback providers are OPENAI_API_KEY and GROQ_API_KEY (already defined above)

# =============================================================================
# E2E TESTING (Telethon userbot)
# =============================================================================
# Get credentials from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your-api-hash-here
E2E_BOT_USERNAME=@test_nika_homes_bot

# =============================================================================
# ALERTING (Telegram notifications via Alertmanager)
# =============================================================================
# Create a separate bot for alerts via @BotFather (not the main bot!)
# See docs/ALERTING.md for setup instructions
TELEGRAM_ALERTING_BOT_TOKEN=your-alerting-bot-token
# Chat ID for alerts (use @userinfobot to get your chat ID)
# For groups: add bot to group and use negative chat ID
TELEGRAM_ALERTING_CHAT_ID=-1001234567890
