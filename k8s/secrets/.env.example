CEREBRAS_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
REDIS_PASSWORD=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
KOMMO_ACCESS_TOKEN=
KOMMO_CLIENT_ID=
KOMMO_CLIENT_SECRET=

# db-credentials
POSTGRES_PASSWORD=
