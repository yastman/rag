# k8s secrets — copy to .env, fill values, then run:
# make k3s-secrets
#
# The same k8s/secrets/.env file is used to generate both:
# - api-keys (all entries except POSTGRES_PASSWORD)
# - db-credentials (POSTGRES_PASSWORD + fixed postgres user/db)

# ─── API Keys ──────────────────────────────────────────────────────────────────

# Bot & LLM providers
TELEGRAM_BOT_TOKEN=
ANTHROPIC_API_KEY=          # litellm, bot
CEREBRAS_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
LITELLM_MASTER_KEY=

# Voice / LiveKit
LIVEKIT_API_KEY=            # livekit-sip, voice-agent
LIVEKIT_API_SECRET=         # livekit-server, livekit-sip, voice-agent
ELEVENLABS_API_KEY=         # voice-agent

# ─── Langfuse (ML observability) ──────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
CLICKHOUSE_PASSWORD=         # langfuse, langfuse-worker
MINIO_ROOT_PASSWORD=         # langfuse-worker, langfuse
LANGFUSE_REDIS_PASSWORD=    # langfuse, langfuse-worker
NEXTAUTH_SECRET=            # langfuse
SALT=                       # langfuse
ENCRYPTION_KEY=             # langfuse

# ─── CRM (Kommo) ─────────────────────────────────────────────────────────────
KOMMO_ACCESS_TOKEN=
KOMMO_CLIENT_ID=
KOMMO_CLIENT_SECRET=

# ─── Infrastructure ───────────────────────────────────────────────────────────
REDIS_PASSWORD=
QDRANT_API_KEY=             # future use

# ─── Database (db-credentials only) ─────────────────────────────────────────
POSTGRES_PASSWORD=
